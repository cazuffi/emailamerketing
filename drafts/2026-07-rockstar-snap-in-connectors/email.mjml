<mjml>
  <mj-head>
    <mj-title>RockStar® Heavy Duty Connectors — SNAP IN Technology</mj-title>
    <mj-preview>Install heavy duty connectors up to 60% faster with SNAP IN technology.</mj-preview>
    <mj-include path="../../components/brand-head.mjml" />
  </mj-head>
  <mj-body background-color="#f4f4f4" width="640px">
    <mj-raw>
<!-- Header: Sales Ignitor campaign tagline -->
<div data-section="true" class="emptyContainer columns-equal-class wrap-section" style="margin: 0px; border-radius: 0px;">
<table class="outer" align="center" cellpadding="0" cellspacing="0" width="640" style="width: 100%; max-width: 640px; display: block;" role="presentation">
<tbody>
<tr>
<th class="mobile-padding" style="padding: 10px;" role="presentation">
<table style="width: 100%; border-collapse: collapse;" class="containerWrapper tbContainer multi" cellpadding="0" cellspacing="0" role="presentation">
<tbody>
<tr>
<th data-container="true" class="columnContainer stack-column col-pad-right" data-container-width="50.00" style="vertical-align: middle; width: 50%;" role="presentation">
<table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tbody><tr>
<th class="inner mobile-center" style="padding: 0px; font-weight: normal;" role="presentation">
<div data-editorblocktype="Image" style="margin: 10px 10px 10px 15px;">
<div align="left" class="imageWrapper" style="width: 100%;">
<img src="https://assets-eur.mkt.dynamics.com/efac8d96-204d-f011-8ee3-6045bd928f41/digitalassets/images/fe07e416-099a-f011-b4cb-7c1e52725572?ts=638943992386672616" width="200" style="max-width: 200px; width: 100%; height: auto; display: block;" alt="Weidmuller">
</div>
</div>
</th>
</tr></tbody></table>
</th>
<th data-container="true" class="columnContainer stack-column stack-column-gap col-pad-left" data-container-width="50.00" style="vertical-align: bottom; width: 50%;" role="presentation">
<table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tbody><tr>
<th class="inner" style="padding: 10px; font-weight: normal;" role="presentation">
<div data-editorblocktype="Text" style="margin: 10px 0px 0px 10px;">
<p class="mobile-text-left" style="margin: 0px; text-align: right;"><span style="font-family: ARIALN, Arial, Verdana, sans-serif; font-size: 15px;">Sales Ignitor&nbsp;</span><span style="color: rgb(239, 120, 0); font-family: ARIALN, Arial, Verdana, sans-serif; font-size: 15px;">|</span><span style="font-family: ARIALN, Arial, Verdana, sans-serif; font-size: 15px;"> RockStar® SNAP IN</span></p>
</div>
</th>
</tr></tbody></table>
